# Copie este arquivo para ".env" e preencha com os valores reais.
# NUNCA commitar o arquivo ".env" (já está no .gitignore).

# --- Conexão Oracle ---
# DSN no formato host:porta/service_name (ex: dbdev.empresa.local:1521/ORCLPDB1)
ORACLE_DSN=host:1521/service_name
ORACLE_USER=usuario_servico
ORACLE_PASSWORD=troque_me

# Pool de conexões
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=4
ORACLE_POOL_INCREMENT=1

# --- Servidor MCP ---
MCP_HOST=127.0.0.1
MCP_PORT=8000
