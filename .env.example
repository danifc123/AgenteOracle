# Copie este arquivo para .env e preencha com os valores reais.
# O .env nunca deve ser commitado (já está no .gitignore).

# Qual banco a aplicação usa: "oracle" (produção) ou "postgres" (teste local)
DB_BACKEND=oracle

# Conexão com o Oracle
ORACLE_DSN=host:porta/service_name
ORACLE_USER=seu_usuario
ORACLE_PASSWORD=sua_senha
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=4
ORACLE_POOL_INCREMENT=1
# Só necessário se o servidor Oracle exigir Native Network Encryption/Data
# Integrity (thin mode não suporta) — caminho do Oracle Instant Client.
ORACLE_CLIENT_LIB_DIR=

# Conexão com o Postgres local (usada quando DB_BACKEND=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agente_oracle
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Servidor MCP
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Ollama (opcional)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Autenticação (login próprio do sistema)
# Chave usada pra assinar o token de login — gere um valor aleatório único
# (ex: python -c "import secrets; print(secrets.token_hex(32))") e nunca
# reutilize entre ambientes. Trocar essa chave desloga todo mundo na hora.
AUTH_SECRET_KEY=
AUTH_TOKEN_HORAS=12
